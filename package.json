{
  "name": "forgecode",
  "version": "0.1.0",
  "description": "An open coding agent built from first principles.",
  "type": "module",
  "bin": {
    "forgecode": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "npm run build --silent && node dist/cli.js",
    "test": "npm run build --silent && node --experimental-strip-types --test tests/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "coding-agent",
    "cli",
    "ai",
    "developer-tools"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.15.29",
    "typescript": "^5.8.3"
  }
}
